<UserControl x:Class="MyClinic.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{DynamicResource AppWindowBg}"
             Foreground="{DynamicResource AppTextPrimary}"
             FontFamily="Segoe UI"
             FontSize="14">

    <UserControl.Resources>

        <!-- Main tab button -->
        <Style x:Key="MainTabBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active main tab -->
        <Style x:Key="MainTabBtnActive" BasedOn="{StaticResource MainTabBtn}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>

        <!-- Subtab button -->
        <Style x:Key="SubTabBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active subtab button -->
        <Style x:Key="SubTabBtnActive" BasedOn="{StaticResource SubTabBtn}" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>

        <!-- Nav arrow button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Now button -->
        <Style x:Key="NowBtn" BasedOn="{StaticResource NavBtn}" TargetType="Button">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- main tabs -->
            <RowDefinition Height="Auto"/>
            <!-- subtabs + date nav -->
            <RowDefinition Height="*"/>
            <!-- pie + legend -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0 — Main tabs ══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppCardBg}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="24,0">
                <Button x:Name="BtnTabIncome"
                        Content="الدخل"
                        Style="{StaticResource MainTabBtnActive}"
                        Click="BtnTabIncome_Click"/>
                <Button x:Name="BtnTabExpenses"
                        Content="المصاريف"
                        Style="{StaticResource MainTabBtn}"
                        Click="BtnTabExpenses_Click"/>
            </StackPanel>
        </Border>

        <!-- ══ Row 1 — Subtabs + date navigation ══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppCardBg}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- subtabs -->
                    <ColumnDefinition Width="*"/>
                    <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- date nav -->
                </Grid.ColumnDefinitions>

                <!-- Subtabs -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnDaily"   Content="يومي"   Style="{StaticResource SubTabBtnActive}" Margin="0,0,6,0" Click="BtnDaily_Click"/>
                    <Button x:Name="BtnMonthly" Content="شهري"   Style="{StaticResource SubTabBtn}"       Margin="0,0,6,0" Click="BtnMonthly_Click"/>
                    <Button x:Name="BtnYearly"  Content="سنوي"   Style="{StaticResource SubTabBtn}"                        Click="BtnYearly_Click"/>
                </StackPanel>

                <!-- Date navigation -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnNow" Content="الآن" Style="{StaticResource NowBtn}" Margin="0,0,10,0" Click="BtnNow_Click"/>
                    <!-- forward (toward future) -->
                    <Button Content="&#8250;" Style="{StaticResource NavBtn}" Margin="0,0,6,0" Click="BtnNext_Click"/>
                    <TextBlock x:Name="TblDateLabel"
                               Text="..."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               VerticalAlignment="Center"
                               MinWidth="160"
                               TextAlignment="Center"
                               Margin="4,0"/>
                    <!-- back (toward past) -->
                    <Button Content="&#8249;" Style="{StaticResource NavBtn}" Margin="6,0,0,0" Click="BtnPrev_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Row 2 — Pie chart + legend ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,24,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total label above pie + pie canvas -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top">

                    <!-- No data message -->
                    <TextBlock x:Name="TblNoData"
                               Text="لا توجد بيانات لهذه الفترة"
                               FontSize="16"
                               Foreground="{DynamicResource AppTextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"
                               Visibility="Collapsed"/>

                    <!-- Pie canvas — FlowDirection LTR to avoid arc mirroring -->
                    <Canvas x:Name="PieCanvas"
                            Width="280" Height="280"
                            FlowDirection="LeftToRight"
                            HorizontalAlignment="Center"/>

                    <!-- Total amount -->
                    <TextBlock x:Name="TblTotal"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               TextAlignment="Center"/>

                </StackPanel>

                <!-- Legend -->
                <Border Grid.Column="2"
                        Background="{DynamicResource AppCardBg}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20,16"
                        Margin="24,0,0,0"
                        VerticalAlignment="Top"
                        MinWidth="200">
                    <StackPanel x:Name="LegendPanel" Orientation="Vertical"/>
                </Border>

            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
