<Window x:Class="MyClinic.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول" Height="550" Width="380" 
        WindowStartupLocation="CenterScreen"
        Background="#111B21"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Icon="Assets/logo.png">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Source="Assets/logo.png" Width="80" Height="80" Margin="0,10,0,30" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality">
            <Image.Clip>
                <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
            </Image.Clip>
        </Image>

        <StackPanel x:Name="pnlSetup" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            
            <TextBlock Text="اسم المستخدم" Foreground="#E9EDEF" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtSetupUsername" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0,5,0" FontSize="14" FontWeight="Bold"/>

            <TextBlock Text="كلمة المرور الجديدة" Foreground="#E9EDEF" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <PasswordBox x:Name="txtSetupPass" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14"/>
                <TextBox x:Name="txtSetupPassVis" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14" Visibility="Collapsed"/>
                <Button x:Name="btnSetupPassEye" Content="&#xE18B;" FontFamily="Segoe MDL2 Assets" Width="35" Height="35" Background="Transparent" Foreground="#555555" BorderThickness="0" HorizontalAlignment="Left" Click="BtnSetupPassEye_Click" Cursor="Hand"/>
            </Grid>

            <TextBlock Text="إعادة إدخال كلمة المرور" Foreground="#E9EDEF" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <PasswordBox x:Name="txtSetupConfirm" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14"/>
                <TextBox x:Name="txtSetupConfirmVis" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14" Visibility="Collapsed"/>
                <Button x:Name="btnSetupConfirmEye" Content="&#xE18B;" FontFamily="Segoe MDL2 Assets" Width="35" Height="35" Background="Transparent" Foreground="#555555" BorderThickness="0" HorizontalAlignment="Left" Click="BtnSetupConfirmEye_Click" Cursor="Hand"/>
            </Grid>

            <Button x:Name="BtnSetPasswordButton" Content="تعيين كلمة المرور" Background="#00A884" Foreground="White" Height="40" FontSize="16" FontWeight="SemiBold" Click="BtnSetPassword_Click" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <StackPanel x:Name="pnlLogin" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            
            <TextBlock Text="اسم المستخدم" Foreground="#E9EDEF" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLoginUsername" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0,5,0" FontSize="14" FontWeight="Bold"/>

            <TextBlock Text="كلمة المرور" Foreground="#E9EDEF" FontSize="14" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <PasswordBox x:Name="txtLoginPass" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14"/>
                <TextBox x:Name="txtLoginPassVis" Height="35" Padding="35,0,5,0" VerticalContentAlignment="Center" FontSize="14" Visibility="Collapsed"/>
                <Button x:Name="btnLoginPassEye" Content="&#xE18B;" FontFamily="Segoe MDL2 Assets" Width="35" Height="35" Background="Transparent" Foreground="#555555" BorderThickness="0" HorizontalAlignment="Left" Click="BtnLoginPassEye_Click" Cursor="Hand"/>
            </Grid>

            <Button x:Name="BtnLoginButton" Content="تسجيل الدخول" Background="#00A884" Foreground="White" Height="40" FontSize="16" FontWeight="SemiBold" Click="BtnLogin_Click" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <TextBlock x:Name="txtError" Grid.Row="2" Text="" Foreground="#F15C6D" FontSize="13" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,15,0,0"/>

    </Grid>
</Window>