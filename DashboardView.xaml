<UserControl x:Class="MyClinic.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{DynamicResource AppWindowBg}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        
        <!-- ============================================== -->
        <!-- إصلاحات الثيم الداكن للـ Scrollbar و DatePicker و ComboBox -->
        <!-- ============================================== -->
        
        <!-- شريط التمرير (ScrollBar) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Margin="2,0,0,0">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{DynamicResource AppBorder}" CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent" Margin="0,2,0,0">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{DynamicResource AppBorder}" CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- مؤشر الكتابة وحقول النص القابلة للتعديل -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- النمط الشامل لـ ComboBox لإصلاح اللون الأبيض في الثيم الداكن -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="Transparent">
                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Margin="8,0,30,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Focusable="True"
                                     Background="Transparent"
                                     Foreground="{DynamicResource AppTextPrimary}"
                                     CaretBrush="{DynamicResource AppTextPrimary}"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     BorderThickness="0"
                                     TextAlignment="Right"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource AppCardBg}" BorderThickness="1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="8" Margin="0,4,0,8">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- عناصر القائمة المنسدلة (ComboBox Item) -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" Margin="2">
                            <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSidebarHoverBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A235DF6"/>
                                <Setter Property="Foreground" Value="#235DF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- نافذة التقويم العامة (Calendar) -->
        <Style TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- صندوق نص التقويم (DatePicker TextBox) -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- أزرار أيام التقويم (Calendar Day Buttons) -->
        <Style TargetType="CalendarDayButton">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#235DF6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- أزرار أشهر/سنوات التقويم -->
        <Style TargetType="CalendarButton">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================== -->
        <!-- أنماط الأزرار والنصوص العامة -->
        <!-- ============================================== -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RangeButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- الهيدر العلوي -->
        <Border Grid.Row="0" Background="#235DF6" CornerRadius="18" Padding="35" Margin="0,0,0,25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="أهلاً د. أحمد" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="رتّب المواعيد القادمة بسرعة واحفظ بيانات المراجعين في مكان واحد." Foreground="#DDE7FF" FontSize="15" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" FlowDirection="LeftToRight" VerticalAlignment="Center">
                    <Button Name="BtnAddPatient" Content="+ إضافة مريض" Width="150" Height="45" Background="White" Foreground="#235DF6" FontSize="16" Margin="0,0,12,0" Style="{StaticResource RoundedButtonStyle}" Click="BtnAddPatient_Click"/>
                    <Button Name="BtnAddAppointment" Content="+ إضافة موعد جديد" Width="170" Height="45" Background="#153DA7" Foreground="White" FontSize="15" BorderThickness="0" Style="{StaticResource RoundedButtonStyle}" Click="BtnAddAppointment_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- المحتوى الرئيسي (البحث، الفلاتر، والمواعيد) -->
        <Border Grid.Row="1" Background="{DynamicResource AppCardBg}" CornerRadius="18" Padding="28" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.04"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- شريط البحث والفلاتر -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="المواعيد" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,0,0,5"/>
                            <TextBlock Text="بطاقات المواعيد تعرض الاسم، الهاتف، السبب، وتوقيت الحجز." FontSize="13" Foreground="{DynamicResource AppTextSecondary}"/>
                        </StackPanel>

                        <!-- البحث التلقائي -->
                        <Border Grid.Column="2" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="10" Padding="5,0">
                            <ComboBox x:Name="CmbAppointmentsSearch"
                                      Width="270" Height="40" IsEditable="True" IsTextSearchEnabled="True"
                                      Foreground="{DynamicResource AppTextPrimary}"
                                      StaysOpenOnEdit="True" BorderThickness="0" Background="Transparent"
                                      VerticalContentAlignment="Center" Padding="8,0"
                                      TextBoxBase.TextChanged="CmbAppointmentsSearch_TextChanged"
                                      SelectionChanged="CmbAppointmentsSearch_SelectionChanged"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" FlowDirection="RightToLeft">
                        <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="2" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnFilterUpcoming" Content="القادمة" Style="{StaticResource RangeButtonStyle}" Width="75" Click="BtnFilterUpcoming_Click"/>
                                <Button x:Name="BtnFilterPast" Content="السابقة" Style="{StaticResource RangeButtonStyle}" Width="75" Click="BtnFilterPast_Click"/>
                                <Button x:Name="BtnFilterAll" Content="الكل" Style="{StaticResource RangeButtonStyle}" Width="60" Click="BtnFilterAll_Click"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnCurrentDate" Content="الشهر الحالي" Height="44" Padding="16,0" Background="#1A235DF6" Foreground="#235DF6" FontWeight="SemiBold" Margin="0,0,12,0" Cursor="Hand" Visibility="Collapsed" Click="BtnCurrentDate_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Border BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Background="{DynamicResource AppInputBg}" Padding="6" Margin="0,0,12,0">
                            <DatePicker x:Name="DpAppointmentsFilter" Width="140" Height="32" Foreground="{DynamicResource AppTextPrimary}" BorderThickness="0" Background="Transparent" SelectedDateChanged="DpAppointmentsFilter_SelectedDateChanged" CalendarOpened="DpAppointmentsFilter_CalendarOpened" CalendarClosed="DpAppointmentsFilter_CalendarClosed"/>
                        </Border>

                        <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnMonthlyView" Content="شهري" Style="{StaticResource RangeButtonStyle}" Width="70" Click="BtnMonthlyView_Click"/>
                                <Button x:Name="BtnDailyView" Content="يومي" Style="{StaticResource RangeButtonStyle}" Width="70" Click="BtnDailyView_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- شبكة البطاقات -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl x:Name="AppointmentsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12" Padding="16" CornerRadius="18" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Background="{DynamicResource AppCardBg}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding PatientName}" FontFamily="Traditional Arabic" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding PhoneNumber}" Margin="0,-4,0,0" FontSize="12" Foreground="{DynamicResource AppTextSecondary}" TextAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Padding="8,5" CornerRadius="9" Background="{Binding ReasonBackground}" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Reason}" Foreground="{Binding ReasonForeground}" FontWeight="Bold" FontSize="12"/>
                                                    </Border>
                                                </Grid>

                                                <Border Grid.Row="1" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#235DF6" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding AppointmentDateText}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" TextAlignment="Right"/>
                                                            <TextBlock Text="{Binding AppointmentTimeText}" FontSize="12" Foreground="{DynamicResource AppTextSecondary}" TextAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="2" Background="{DynamicResource AppInputBg}" CornerRadius="12" Padding="10" Margin="0,0,0,10">
                                                    <StackPanel HorizontalAlignment="Right">
                                                        <TextBlock Text="سبب الموعد" FontSize="11" Foreground="{DynamicResource AppTextSecondary}" TextAlignment="Right"/>
                                                        <TextBlock Text="{Binding Reason}" Margin="0,4,0,0" FontSize="13" FontWeight="Bold" Foreground="#2447E4" TextAlignment="Right"/>
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Row="3" Text="موعد محفوظ في جدول العيادة" FontSize="11" Foreground="{DynamicResource AppTextSecondary}" TextAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel x:Name="EmptyAppointmentsState" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,0">
                                <Border Width="74" Height="74" CornerRadius="37" Background="{DynamicResource AppInputBg}" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="لا توجد مواعيد مطابقة للبحث أو التاريخ المحدد" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                                <TextBlock Text="أضف موعداً جديداً أو قم بتغيير فلاتر البحث والوقت." FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <Border x:Name="LoadingOverlay" Background="#A00F172A" Visibility="Collapsed">
                        <Border Width="260" Height="120" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="جارٍ تحميل المواعيد" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Center"/>
                                <ProgressBar Width="180" Height="8" Margin="0,18,0,0" IsIndeterminate="True" Foreground="#235DF6" Background="{DynamicResource AppInputBg}"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- نافذة إضافة موعد جديد -->
        <Grid x:Name="AppointmentDialogOverlay" Grid.RowSpan="2" Panel.ZIndex="20" Visibility="Collapsed">
            <Border Background="#A00F172A" MouseLeftButtonDown="AppointmentDialogBackdrop_MouseLeftButtonDown"/>

            <Border Width="560" Padding="32" Background="{DynamicResource AppCardBg}" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" BlurRadius="40" ShadowDepth="10" Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- رأس النافذة -->
                    <Grid Grid.Row="0" Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- زر الإغلاق -->
                        <Button Grid.Column="0" Width="36" Height="36" Background="{DynamicResource AppInputBg}" BorderThickness="0" Click="BtnCloseAppointmentDialog_Click" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="إضافة موعد جديد" FontFamily="Traditional Arabic" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,0,10,0"/>
                                <Border Width="38" Height="38" Background="#1A235DF6" CornerRadius="12">
                                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#235DF6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="أدخل بيانات المريض والوقت لتسجيل الموعد في الجدول." Margin="0,-2,0,0" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <!-- الصف الأول -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="اسم المريض" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="4,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource IconTextStyle}" Text="&#xE77B;"/>
                                    <ComboBox x:Name="CmbAppointmentPatientName"
                                              Height="44" Padding="8,0" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppTextPrimary}"
                                              VerticalContentAlignment="Center" IsEditable="True" IsTextSearchEnabled="False"
                                              SelectionChanged="CmbAppointmentPatientName_SelectionChanged"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="رقم الهاتف" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="4,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource IconTextStyle}" Text="&#xE717;" FontSize="15"/>
                                    <ComboBox x:Name="CmbAppointmentPhoneNumber"
                                              Height="44" Padding="8,0" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppTextPrimary}"
                                              VerticalContentAlignment="Center" IsEditable="True" IsTextSearchEnabled="False"
                                              SelectionChanged="CmbAppointmentPhoneNumber_SelectionChanged"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- الصف الثاني -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="سبب الزيارة" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="4,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource IconTextStyle}" Text="&#xE946;"/>
                                <ComboBox x:Name="CmbAppointmentReason" Height="44" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppTextPrimary}" Padding="8,0" SelectedIndex="0" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="معاينة جديدة"/>
                                    <ComboBoxItem Content="مراجعة"/>
                                </ComboBox>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <!-- الصف الثالث -->
                    <Grid Grid.Row="3" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="تاريخ الموعد" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="4,0">
                                <DatePicker x:Name="DpAppointmentDate" Height="44" Background="Transparent" Foreground="{DynamicResource AppTextPrimary}" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="وقت الموعد" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="4,0" Height="44">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource IconTextStyle}" Text="&#xE823;"/>
                                    <Grid FlowDirection="LeftToRight" Margin="8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CmbHour" Grid.Column="0" Background="Transparent" Foreground="{DynamicResource AppTextPrimary}" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="2"/>
                                        <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="2,0"/>
                                        <ComboBox x:Name="CmbMinute" Grid.Column="2" Background="Transparent" Foreground="{DynamicResource AppTextPrimary}" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="2"/>
                                        <ComboBox x:Name="CmbAmPm" Grid.Column="4" Background="Transparent" Foreground="{DynamicResource AppTextPrimary}" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="2" Margin="4,0,0,0"/>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- الصف الرابع -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" FlowDirection="LeftToRight" HorizontalAlignment="Left">
                        <Button Content="حفظ الموعد" Width="140" Height="48" Background="#235DF6" Foreground="White" BorderThickness="0" Margin="0,0,12,0" Style="{StaticResource RoundedButtonStyle}" Click="BtnSaveAppointment_Click"/>
                        <Button Content="إلغاء الأمر" Width="110" Height="48" Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Style="{StaticResource RoundedButtonStyle}" Click="BtnCloseAppointmentDialog_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>