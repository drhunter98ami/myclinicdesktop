<UserControl x:Class="MyClinic.AdultDentalChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="850" Height="300">

    <UserControl.Resources>
        <SolidColorBrush x:Key="ToothOutline" Color="#1E293B"/>
        <SolidColorBrush x:Key="ToothFill" Color="White"/>
        <SolidColorBrush x:Key="ToothHover" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="ToothSelected" Color="#3B82F6"/>
        
        <Style x:Key="UpperToothStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource ToothFill}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="45" Height="70">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="{TemplateBinding Content}" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            
                            <Grid Grid.Row="1" Width="40" Height="40" x:Name="ToothBody">
                                <Path x:Name="ToothPath"
                                      Data="M 10,3 C 5,3 5,18 8,23 C 10,33 10,38 12,38 C 15,38 18,28 20,23 C 22,28 25,38 28,38 C 30,38 30,33 32,23 C 35,18 35,3 30,3 C 25,3 22,10 20,10 C 18,10 15,3 10,3 Z" 
                                      Fill="{TemplateBinding Background}" 
                                      Stroke="{StaticResource ToothOutline}" 
                                      StrokeThickness="1.5" 
                                      StrokeLineJoin="Round"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleY="-1"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToothBody" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToothPath" Property="Fill" Value="{StaticResource ToothSelected}"/>
                                <Setter Property="Foreground" Value="{StaticResource ToothSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LowerToothStyle" TargetType="ToggleButton" BasedOn="{StaticResource UpperToothStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="45" Height="70">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Width="40" Height="40" x:Name="ToothBody">
                                <Path x:Name="ToothPath"
                                      Data="M 10,3 C 5,3 5,18 8,23 C 10,33 10,38 12,38 C 15,38 18,28 20,23 C 22,28 25,38 28,38 C 30,38 30,33 32,23 C 35,18 35,3 30,3 C 25,3 22,10 20,10 C 18,10 15,3 10,3 Z" 
                                      Fill="{TemplateBinding Background}" 
                                      Stroke="{StaticResource ToothOutline}" 
                                      StrokeThickness="1.5" 
                                      StrokeLineJoin="Round"/>
                            </Grid>
                            
                            <TextBlock Grid.Row="1" Text="{TemplateBinding Content}" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToothBody" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToothPath" Property="Fill" Value="{StaticResource ToothSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/> 
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="30"/> 
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="28" Grid.Row="0" Grid.Column="0"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="27" Grid.Row="0" Grid.Column="1"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="26" Grid.Row="0" Grid.Column="2"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="25" Grid.Row="0" Grid.Column="3"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="24" Grid.Row="0" Grid.Column="4"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="23" Grid.Row="0" Grid.Column="5"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="22" Grid.Row="0" Grid.Column="6"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="21" Grid.Row="0" Grid.Column="7"/>

            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="11" Grid.Row="0" Grid.Column="9"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="12" Grid.Row="0" Grid.Column="10"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="13" Grid.Row="0" Grid.Column="11"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="14" Grid.Row="0" Grid.Column="12"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="15" Grid.Row="0" Grid.Column="13"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="16" Grid.Row="0" Grid.Column="14"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="17" Grid.Row="0" Grid.Column="15"/>
            <ToggleButton Style="{StaticResource UpperToothStyle}" Content="18" Grid.Row="0" Grid.Column="16"/>

            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="38" Grid.Row="2" Grid.Column="0"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="37" Grid.Row="2" Grid.Column="1"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="36" Grid.Row="2" Grid.Column="2"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="35" Grid.Row="2" Grid.Column="3"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="34" Grid.Row="2" Grid.Column="4"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="33" Grid.Row="2" Grid.Column="5"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="32" Grid.Row="2" Grid.Column="6"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="31" Grid.Row="2" Grid.Column="7"/>

            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="41" Grid.Row="2" Grid.Column="9"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="42" Grid.Row="2" Grid.Column="10"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="43" Grid.Row="2" Grid.Column="11"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="44" Grid.Row="2" Grid.Column="12"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="45" Grid.Row="2" Grid.Column="13"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="46" Grid.Row="2" Grid.Column="14"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="47" Grid.Row="2" Grid.Column="15"/>
            <ToggleButton Style="{StaticResource LowerToothStyle}" Content="48" Grid.Row="2" Grid.Column="16"/>
            
            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="8" BorderBrush="#CBD5E1" BorderThickness="2,0,0,0" Margin="14,10,0,10"/>
        </Grid>
    </Viewbox>
</UserControl>