<!-- AddPatientView.xaml -->
<UserControl x:Class="MyClinic.AddPatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MyClinic"
             FlowDirection="RightToLeft"
             Background="{DynamicResource AppWindowBg}"
             FontFamily="Segoe UI"
             FontSize="14">

    <UserControl.Resources>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ModernTextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="6" Background="{DynamicResource AppInputBg}">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="{DynamicResource AppTextSecondary}" Margin="12,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ComboBox" x:Key="ModernComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          Background="{TemplateBinding Background}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Focusable="false" 
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                            <Path x:Name="Arrow" Fill="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource AppCardBg}" BorderThickness="1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Margin="0,4,0,0">
                                        <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSidebarHoverBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryActionButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryActionButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="SoftSectionCard">
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style TargetType="Button" x:Key="FlatCardButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VisitEntryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.94"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModalHeaderChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DetailSectionStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Width" Value="146"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="تسجيل زيارة جديدة" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center"/>
                <Border Width="6" Height="26" Background="#2563EB" CornerRadius="3" Margin="15,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- ROW 0: Top Section (Side-by-Side Layout) -->
                
                <!-- Left Column (Clinical Data Top) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">
                    
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="اختيار العلاجات" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                            
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="TreatmentItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AppInputBg}" 
                                                    BorderBrush="{DynamicResource AppBorder}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="6" 
                                                    Padding="12,8"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0" 
                                                              x:Name="ChkTreatment"
                                                              IsChecked="{Binding IsSelected}"
                                                              Checked="TreatmentCheckBox_Changed" 
                                                              Unchecked="TreatmentCheckBox_Changed"
                                                              Margin="0,0,12,0"
                                                              VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding TreatmentName}" 
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource AppTextPrimary}"/>

                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding Cost, StringFormat={}{0:N0}}" 
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource AppTextSecondary}"/>

                                                    <TextBlock Grid.Column="3" 
                                                               Text="×" 
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource AppTextSecondary}"
                                                               Margin="5,0"/>

                                                    <TextBox Grid.Column="4" 
                                                                     x:Name="TxtQuantity"
                                                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                                     TextAlignment="Center"
                                                                     Style="{StaticResource ModernTextBox}"
                                                                     Height="32"
                                                                     TextChanged="TreatmentQuantity_TextChanged"
                                                                     IsEnabled="{Binding IsSelected}"
                                                                     VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="البيانات المالية" Foreground="{DynamicResource AppTextPrimary}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="تفاصيل الدفع والتكلفة" Foreground="{DynamicResource AppTextSecondary}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="10,0">
                                    <TextBlock Text="التكلفة الحالية" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtCurrentCost" Text="0" TextAlignment="Center" Style="{StaticResource ModernTextBox}" TextChanged="FinancialInput_TextChanged"
                                             GotKeyboardFocus="TextBox_GotKeyboardFocus" 
                                             PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="دفعة اليوم" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtTodayPaid" Text="0" TextAlignment="Center" Style="{StaticResource ModernTextBox}" TextChanged="FinancialInput_TextChanged"
                                             GotKeyboardFocus="TextBox_GotKeyboardFocus" 
                                             PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"/>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Margin="10,0">
                                    <TextBlock Text="العملة" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <ComboBox x:Name="CmbCurrency" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                        <ComboBoxItem Content="SYP"/>
                                        <ComboBoxItem Content="USD"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="متبقي الزيارة" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtRemainingAmount" Text="0" TextAlignment="Center" Style="{StaticResource ModernTextBox}" Background="{DynamicResource AppInputBg}" IsReadOnly="True" Foreground="#16A34A" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Border x:Name="PatientFinancialHistoryPanel" Visibility="Collapsed" Margin="0,15,0,0" Padding="15" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="السجل المالي التراكمي للمريض:" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        
                                        <TextBlock Text="إجمالي التكلفة:" Foreground="{DynamicResource AppTextSecondary}" Margin="20,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtTotalPatientCost" Text="0" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center" FontSize="15"/>
                                        
                                        <TextBlock Text="إجمالي الدفعات:" Foreground="{DynamicResource AppTextSecondary}" Margin="20,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtTotalPatientPaid" Text="0" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center" FontSize="15"/>
                                        
                                        <TextBlock Text="إجمالي المتبقي:" Foreground="{DynamicResource AppTextSecondary}" Margin="20,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtTotalPatientRemaining" Text="0" FontWeight="Bold" Foreground="#DC2626" VerticalAlignment="Center" FontSize="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}">
                        <StackPanel>
                            <TextBlock Text="عادات التدخين" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Left"/>
                            <CheckBox x:Name="ChkSmoker" Content="المريض مدخن" Margin="0,10,0,0" FlowDirection="RightToLeft" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold" Checked="ChkSmoker_CheckedChanged" Unchecked="ChkSmoker_CheckedChanged"/>
                            
                            <StackPanel x:Name="PanelSmokerDetails" Visibility="Collapsed" Margin="0,15,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="نوع التدخين" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtSmokingType" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="التكرار" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtSmokingFrequency" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="CardFemaleDetails" Visibility="Collapsed" Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}">
                        <StackPanel>
                            <TextBlock Text="الصحة الإنجابية" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox x:Name="ChkPregnant" Content="حامل" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,0,0,0" Checked="ChkPregnant_CheckedChanged" Unchecked="ChkPregnant_CheckedChanged"/>
                                <CheckBox x:Name="ChkNursing" Content="مرضع" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Margin="20,0,0,0"/>
                            </StackPanel>
                            
                            <StackPanel x:Name="PanelPregnancyMonth" Visibility="Collapsed" Margin="0,15,0,0">
                                <TextBlock Text="شهر الحمل" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="CmbPregnancyMonth" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                    <ComboBoxItem Content="الشهر الأول"/>
                                    <ComboBoxItem Content="الشهر الثاني"/>
                                    <ComboBoxItem Content="الشهر الثالث"/>
                                    <ComboBoxItem Content="الشهر الرابع"/>
                                    <ComboBoxItem Content="الشهر الخامس"/>
                                    <ComboBoxItem Content="الشهر السادس"/>
                                    <ComboBoxItem Content="الشهر السابع"/>
                                    <ComboBoxItem Content="الشهر الثامن"/>
                                    <ComboBoxItem Content="الشهر التاسع"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}" Margin="0,0,10,15">
                            <StackPanel>
                                <TextBlock Text="الحساسية والتحذيرات" FontSize="17" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Left"/>
                                <TextBox x:Name="TxtAllergies" Height="NaN" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Margin="0,10,0,0" Style="{StaticResource ModernTextBox}" Padding="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}" Margin="10,0,0,15">
                            <StackPanel>
                                <TextBlock Text="الأمراض المزمنة" FontSize="17" FontWeight="Bold" Foreground="#F97316" HorizontalAlignment="Left"/>
                                <TextBox x:Name="TxtChronicDiseases" Height="NaN" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Margin="0,10,0,0" Style="{StaticResource ModernTextBox}" Padding="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}">
                        <StackPanel>
                            <TextBlock Text="العلامات الحيوية (Vital Signs)" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="10,0">
                                    <TextBlock Text="ضغط الدم (BP)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtBloodPressure" Tag="120/80" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="النبض (HR)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtHeartRate" Tag="72" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="10,0">
                                    <TextBlock Text="الحرارة (Temp)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtTemperature" Tag="37.0" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="10,0">
                                    <TextBlock Text="التنفس (RR)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtRespiratoryRate" Tag="16" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="10,0">
                                    <TextBlock Text="الوزن (Weight)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtWeight" Tag="70" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="الطول (Height)" Style="{StaticResource FormLabel}" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="TxtHeight" Tag="170" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="الأعراض (Symptoms)" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Left"/>
                                <TextBox x:Name="TxtSymptoms" Height="NaN" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,10,0,0" Style="{StaticResource ModernTextBox}" VerticalContentAlignment="Top" Padding="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="التشخيص (Diagnosis)" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Left"/>
                                <TextBox x:Name="TxtDiagnosis" Height="NaN" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,10,0,0" Style="{StaticResource ModernTextBox}" VerticalContentAlignment="Top" Padding="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Right Column (Personal Data Sidebar Top) -->
                <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="البيانات الشخصية" Foreground="{DynamicResource AppTextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <Separator Background="{DynamicResource AppBorder}" Margin="0,0,0,15"/>

                            <TextBlock Text="رقم الهاتف *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtPhoneNumber" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"
                                     TextChanged="PatientLookup_TextChanged"/>

                            <TextBlock Text="الاسم الثلاثي" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtFullName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"
                                     TextChanged="PatientLookup_TextChanged"/>

                            <Border x:Name="PatientSuggestionsPanel" Style="{StaticResource SoftSectionCard}" Margin="0,0,0,15" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="مطابقات سابقة" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    <TextBlock x:Name="TxtPatientSuggestionsHint" Text="اختر المريض المناسب لتعبئة البيانات تلقائياً." Margin="0,4,0,10" Foreground="{DynamicResource AppTextSecondary}"/>

                                    <ScrollViewer MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ItemsPatientSuggestions">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource FlatCardButton}" Tag="{Binding}" Click="BtnApplyPatientSuggestion_Click" Margin="0,0,0,8">
                                                        <Border Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="10" Padding="12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                                                    <TextBlock Text="{Binding SecondaryLine}" Margin="0,4,0,0" Foreground="{DynamicResource AppTextSecondary}"/>
                                                                    <TextBlock Text="{Binding MetaLine}" Margin="0,4,0,0" Foreground="{DynamicResource AppTextSecondary}" FontSize="12"/>
                                                                </StackPanel>

                                                                <Border Grid.Column="1" Background="#2563EB" CornerRadius="999" Padding="12,6" Margin="12,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding MatchReason}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="العمر" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="TxtAge" Text="0" Style="{StaticResource ModernTextBox}"
                                             GotKeyboardFocus="TextBox_GotKeyboardFocus" 
                                             PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="الجنس" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="CmbGender" Style="{StaticResource ModernComboBox}" SelectedIndex="0" SelectionChanged="CmbGender_SelectionChanged">
                                        <ComboBoxItem Content="ذكر"/>
                                        <ComboBoxItem Content="أنثى"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="زمرة الدم" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="CmbBloodType" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="غير محدد" IsSelected="True"/>
                                <ComboBoxItem Content="A+"/>
                                <ComboBoxItem Content="A-"/>
                                <ComboBoxItem Content="B+"/>
                                <ComboBoxItem Content="B-"/>
                                <ComboBoxItem Content="O+"/>
                                <ComboBoxItem Content="O-"/>
                                <ComboBoxItem Content="AB+"/>
                                <ComboBoxItem Content="AB-"/>
                            </ComboBox>

                            <!-- Previous Visits Panel -->
                            <Border x:Name="PreviousVisitsPanel"
                                    Margin="0,15,0,0"
                                    Padding="0"
                                    Background="{DynamicResource AppInputBg}"
                                    CornerRadius="18"
                                    BorderThickness="0"
                                    Visibility="Collapsed">
                                
                                <StackPanel>
                                    <Border CornerRadius="18,18,0,0" Padding="16,14,16,10" Background="{DynamicResource AppSidebarBg}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    MinWidth="28" Height="28"
                                                    Padding="8,0"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource AppSidebarHoverBg}">
                                                <TextBlock x:Name="TxtPreviousVisitsCount"
                                                           Text="0"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       x:Name="TxtPreviousVisitsHint"
                                                       Text="الزيارات المسجلة"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                        </Grid>
                                    </Border>

                                    <ListBox x:Name="ItemsPreviousVisits"
                                             MaxHeight="320"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="10,8"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             VirtualizingStackPanel.IsVirtualizing="True"
                                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource VisitEntryButtonStyle}"
                                                        Tag="{Binding}"
                                                        Click="BtnOpenPreviousVisit_Click">
                                                    <Border Margin="0,0,0,14"
                                                            Padding="16"
                                                            CornerRadius="14"
                                                            Background="{DynamicResource AppCardBg}"
                                                            BorderBrush="{DynamicResource AppBorder}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <Grid Grid.Row="0" FlowDirection="LeftToRight">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding VisitDateText}"
                                                                           FontSize="15"
                                                                           Foreground="{DynamicResource AppTextSecondary}"/>

                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            FlowDirection="RightToLeft">
                                                                    <TextBlock Text="&#xE8A5;"
                                                                               FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="15"
                                                                               Foreground="{DynamicResource AppTextSecondary}"
                                                                               Margin="0,0,8,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding AttachmentLabel}"
                                                                               FontSize="13"
                                                                               Foreground="{DynamicResource AppTextSecondary}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>

                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding Title}"
                                                                       FontFamily="Traditional Arabic"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource AppTextPrimary}"
                                                                       TextWrapping="Wrap"
                                                                       TextAlignment="Right"
                                                                       Margin="0,10,0,6"/>

                                                            <Grid Grid.Row="2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0"
                                                                           Text="&#xE76C;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource AppTextSecondary}"
                                                                           VerticalAlignment="Center"/>

                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Details}"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource AppTextSecondary}"
                                                                           TextWrapping="Wrap"
                                                                           TextAlignment="Right"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock x:Name="EmptyPreviousVisitsText"
                                               Text="لا توجد زيارات محفوظة لهذا المريض حتى الآن."
                                               FontSize="15"
                                               Foreground="{DynamicResource AppTextSecondary}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ROW 1: Bottom Section (Spans across both columns safely underneath the above rows) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0" VerticalAlignment="Top">
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,0,0,15">
                        <Border Background="{DynamicResource AppInputBg}" CornerRadius="20" Padding="5" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnAdult" Content="بالغين" Width="100" Height="40" Background="{DynamicResource AppCardBg}" BorderThickness="0" Foreground="{DynamicResource AppTextPrimary}" FontWeight="Bold" Click="BtnAdult_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                
                                <Button x:Name="BtnChild" Content="أطفال" Width="100" Height="40" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppTextSecondary}" FontWeight="Bold" Click="BtnChild_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource Card}" Margin="0" MinHeight="450" HorizontalAlignment="Stretch">
                            <Grid>
                                <local:AdultDentalChart x:Name="AdultChartControl" Visibility="Visible"/>
                                <local:ChildrenDentalChart x:Name="ChildChartControl" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Prescriptions Full Space Left -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Border Style="{StaticResource Card}" Background="{DynamicResource AppInputBg}" Margin="0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,15">
                                        <Border Width="38" Height="38" CornerRadius="10" Background="#2563EB" DockPanel.Dock="Right">
                                            <TextBlock Text="🧾" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="الوصفة الطبية" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                            <TextBlock Text="أضف الأدوية والتعليمات الخاصة بالزيارة الحالية" Foreground="{DynamicResource AppTextSecondary}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="اسم الدواء" Style="{StaticResource FormLabel}"/>
                                    <!-- Autofill implementation -->
                                    <Grid Margin="0,0,0,12">
                                        <TextBox x:Name="TxtPrescriptionMedicine" Tag="ابحث عن دواء أو اكتب دواء جديد..." Style="{StaticResource ModernTextBox}" TextChanged="TxtPrescriptionMedicine_TextChanged"/>
                                        <Popup x:Name="PopupMedicineSuggestions" PlacementTarget="{Binding ElementName=TxtPrescriptionMedicine}" Placement="Bottom" AllowsTransparency="True" IsOpen="False" StaysOpen="False" MaxHeight="200">
                                            <Border Background="{DynamicResource AppCardBg}" BorderThickness="1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Margin="0,4,0,0" Width="{Binding ElementName=TxtPrescriptionMedicine, Path=ActualWidth}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#1A000000" BlurRadius="10" ShadowDepth="4"/>
                                                </Border.Effect>
                                                <ListBox x:Name="LstMedicineSuggestions" Background="Transparent" BorderThickness="0" SelectionChanged="LstMedicineSuggestions_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Padding="10,8" Foreground="{DynamicResource AppTextPrimary}" FontSize="14" Cursor="Hand"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border Background="{TemplateBinding Background}" Padding="0">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource AppSidebarHoverBg}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <TextBlock Text="آخر وصفات سريعة (سجل تلقائي)" Foreground="{DynamicResource AppTextSecondary}" Margin="0,0,0,8"/>
                                    <!-- Dynamic wrap panel of recent medicines -->
                                    <ItemsControl x:Name="ItemsRecentMedicines" Margin="0,0,0,12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource FlatCardButton}" Click="BtnRecentMedicine_Click" Tag="{Binding}" Margin="0,0,8,8">
                                                    <Border Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="14" Padding="12,6">
                                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource AppTextPrimary}"/>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="العيار" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtPrescriptionDosage" Tag="500mg" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="التكرار (ساعات)" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtPrescriptionFrequency" Tag="8" Style="{StaticResource ModernTextBox}" TextAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                            <TextBlock Text="التوقيت" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="CmbPrescriptionTiming" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                                <ComboBoxItem Content="بعد الطعام"/>
                                                <ComboBoxItem Content="قبل الطعام"/>
                                                <ComboBoxItem Content="عند اللزوم"/>
                                                <ComboBoxItem Content="قبل النوم"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="ملاحظات إضافية" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="TxtPrescriptionNotes" Height="78" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10" Style="{StaticResource ModernTextBox}"/>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="إضافة للوصفة" Style="{StaticResource PrimaryActionButton}" Width="150" Click="BtnAddPrescription_Click"/>
                                        <Button Grid.Column="1" Content="حذف المحدد" Style="{StaticResource SecondaryActionButton}" Width="120" Margin="10,0,0,0" Click="BtnRemovePrescription_Click"/>
                                    </Grid>

                                    <TextBlock Text="عناصر الوصفة" Style="{StaticResource FormLabel}"/>
                                    <ListBox x:Name="LstPrescriptionEntries"
                                             MinHeight="120"
                                             Background="{DynamicResource AppCardBg}"
                                             BorderBrush="{DynamicResource AppBorder}"
                                             BorderThickness="1"
                                             Foreground="{DynamicResource AppTextPrimary}"
                                             Padding="6"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Attachments & Notes Full Space Right -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="صور الزيارة" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    <TextBlock Text="يمكنك إرفاق حتى 5 صور للملفات أو الأشعة أو المرفقات السريرية" Foreground="{DynamicResource AppTextSecondary}" Margin="0,6,0,15"/>

                                    <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="18">
                                        <Grid>
                                            <Rectangle Stroke="{DynamicResource AppTextSecondary}"
                                                       StrokeThickness="1.5"
                                                       StrokeDashArray="5 4"
                                                       RadiusX="10"
                                                       RadiusY="10"/>
                                            <StackPanel Margin="12" HorizontalAlignment="Center">
                                                <TextBlock Text="اضغط لاختيار الصور من الجهاز" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Center" Margin="0,8,0,8"/>
                                                <TextBlock x:Name="TxtImageSelectionHint" Text="لا توجد صور محددة بعد" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="اختيار الصور" Style="{StaticResource PrimaryActionButton}" Width="130" Click="BtnSelectImages_Click"/>
                                                    <Button Content="مسح الكل" Style="{StaticResource SecondaryActionButton}" Width="100" Margin="10,0,0,0" Click="BtnClearImages_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="الصور المحددة" Style="{StaticResource FormLabel}" Margin="0,15,0,8"/>
                                    <ListBox x:Name="LstSelectedImages"
                                             MinHeight="120"
                                             Background="{DynamicResource AppCardBg}"
                                             BorderBrush="{DynamicResource AppBorder}"
                                             BorderThickness="1"
                                             Foreground="{DynamicResource AppTextPrimary}"
                                             Padding="6"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="ملاحظات وخطة العلاج" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    <TextBlock Text="سجّل الخطة القادمة أو أي ملاحظات مهمة للطبيب" Foreground="{DynamicResource AppTextSecondary}" Margin="0,6,0,12"/>
                                    <TextBox x:Name="TxtTreatmentPlanNotes"
                                             Height="NaN"
                                             MinHeight="100"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalContentAlignment="Top"
                                             Padding="10"
                                             Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnSaveVisit" Content="حفظ وإنهاء الزيارة" Width="150" Height="45" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="16" Cursor="Hand" Margin="0,0,10,0" Click="BtnSaveVisit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="إلغاء" Width="100" Height="45" Style="{StaticResource SecondaryActionButton}" FontSize="16" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>

        <!-- Fully Rebuilt Visit Details Modal matched to PatientRecordsView style -->
        <Grid x:Name="VisitDetailsOverlay" Grid.RowSpan="3" Visibility="Collapsed" Panel.ZIndex="25">
            <Border x:Name="VisitDetailsDimmer" Background="#A3000000" MouseLeftButtonDown="VisitDetailsDimmer_MouseLeftButtonDown"/>

            <Border x:Name="VisitDetailsModal" Width="760" MaxHeight="900" Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource AppWindowBg}" CornerRadius="28" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="VisitDetailsTranslate" Y="24"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#26000000" BlurRadius="36" ShadowDepth="10" Opacity="0.28"/>
                </Border.Effect>

                <Grid FlowDirection="RightToLeft">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="28,18,28,12" FlowDirection="LeftToRight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Width="34" Height="34" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseVisitDetails_Click">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Width="52" Height="52" CornerRadius="16" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Margin="0,0,14,0">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="تفاصيل الزيارة الطبية" FontFamily="Traditional Arabic" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding PatientName}" FontSize="15" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right" Margin="0,-8,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid HorizontalAlignment="Right" Margin="0,18,0,0" FlowDirection="LeftToRight">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource ModalHeaderChipStyle}">
                                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#0EA5A8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VisitDateTimeText}" FontSize="14" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource ModalHeaderChipStyle}">
                                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#2563EB" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DoctorName, FallbackValue='طبيب العيادة'}" FontSize="14" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="0" Height="1" Background="{DynamicResource AppBorder}" VerticalAlignment="Bottom"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20,28,6">
                        <StackPanel>
                            
                            <!-- Patient Information Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#7C3AED" Margin="0,0,10,0"/>
                                        <TextBlock Text="معلومات المريض عند وقت الزيارة" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#7C3AED"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="زمرة الدم" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding BloodTypeText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الحساسية" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding AllergiesText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الأمراض المزمنة" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding ChronicDiseasesText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="عادات التدخين" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding SmokingText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الحمل والرضاعة" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PregnancyText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Vital Signs Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#16A34A" Margin="0,0,10,0"/>
                                        <TextBlock Text="العلامات الحيوية" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#16A34A"/>
                                    </StackPanel>

                                    <WrapPanel FlowDirection="RightToLeft">
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="ضغط الدم" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding BloodPressureText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="النبض" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding HeartRateText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="الحرارة" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding TemperatureText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="التنفس" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding RespiratoryRateText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="الوزن" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding WeightText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="الطول / BMI" Foreground="{DynamicResource AppTextSecondary}" FontSize="13"/>
                                                <TextBlock Text="{Binding HeightText}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding BmiText}" Foreground="#2563EB" FontSize="13" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Symptoms and Diagnosis Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#DC2626" Margin="0,0,10,0"/>
                                        <TextBlock Text="الأعراض والتشخيص" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#DC2626"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="الأعراض" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                            <TextBlock Text="{Binding SymptomsText}" Margin="0,6,0,0" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="التشخيص" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                            <TextBlock Text="{Binding DiagnosisText}" Margin="0,6,0,0" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Treatment Plan Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#0284C7" Margin="0,0,10,0"/>
                                        <TextBlock Text="خطة العلاج وملاحظات" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#0284C7"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="خطة العلاج" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                        <TextBlock Text="{Binding TreatmentPlanText}" Margin="0,6,0,0" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Dental Record Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xEFA9;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#9333EA" Margin="0,0,10,0"/>
                                        <TextBlock Text="المخطط السني" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#9333EA"/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{Binding DentalChartCategoryText}" Margin="0,0,0,16" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold"/>
                                    
                                    <TextBlock Text="الأسنان المسجلة" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    <ItemsControl ItemsSource="{Binding Teeth}" Margin="0,10,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="999" Padding="12,6" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTeeth}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>
                                    <TextBlock Text="لا توجد أسنان محددة في هذه الزيارة." Margin="0,6,0,0" Foreground="{DynamicResource AppTextSecondary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTeeth}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Prescriptions Section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#D97706" Margin="0,0,10,0"/>
                                        <TextBlock Text="الوصفة الطبية" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="#D97706"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding PrescriptionItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding MedicineName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                                        <TextBlock Text="{Binding InstructionText}" Margin="0,6,0,0" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPrescriptions}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>
                                    <TextBlock Text="لا توجد أدوية مسجلة لهذه الزيارة." Margin="0,4,0,0" Foreground="{DynamicResource AppTextSecondary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPrescriptions}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Attachments Section -->
                            <Border Style="{StaticResource DetailSectionStyle}" Margin="0,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AppTextSecondary}" Margin="0,0,10,0"/>
                                        <TextBlock Text="المرفقات" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                        <TextBlock Text="{Binding AttachmentCountText}" Margin="10,0,0,0" Foreground="#6366F1" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding AttachmentItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource FlatCardButton}" Tag="{Binding}" Click="OpenVisitAttachment_Click" Margin="0,0,0,8">
                                                    <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Image Grid.Column="0" Source="{Binding Thumbnail}" Width="60" Height="60" Stretch="UniformToFill" Margin="0,0,16,0"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="اضغط لفتح الملف" Margin="0,4,0,0" Foreground="{DynamicResource AppTextSecondary}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>
                                    <TextBlock Text="لا توجد صور أو مرفقات لهذه الزيارة." Margin="0,4,0,0" Foreground="{DynamicResource AppTextSecondary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" CornerRadius="0,0,28,28" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="16">
                        <Button Content="إغلاق" Width="96" Height="40" HorizontalAlignment="Left" Click="CloseVisitDetails_Click" Style="{StaticResource SecondaryActionButton}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>