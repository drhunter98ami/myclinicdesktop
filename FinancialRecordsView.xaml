<UserControl x:Class="MyClinic.FinancialRecordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{DynamicResource AppWindowBg}"
             Foreground="{DynamicResource AppTextPrimary}"
             FontFamily="Segoe UI"
             FontSize="14">

    <UserControl.Resources>
        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RangeButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}"
                                           Margin="12,0"
                                           Foreground="{DynamicResource AppTextSecondary}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="28"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="58"
                                Height="58"
                                CornerRadius="16"
                                Background="{DynamicResource AppInputBg}"
                                HorizontalAlignment="Right">
                            <TextBlock Text="&#xE8C7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28"
                                       Foreground="#3B82F6"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="18,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="الإدارة المالية"
                                       FontFamily="Traditional Arabic"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextPrimary}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="تتبع الدخل والمصاريف والدفع المالي للمرضى"
                                       Margin="0,-8,0,0"
                                       FontSize="16"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Summary Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="0,0,10,0"
                            Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="44"
                                    Height="44"
                                    CornerRadius="12"
                                    Background="{DynamicResource AppInputBg}">
                                <TextBlock Text="&#xE8FB;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="22"
                                           Foreground="#10B981"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="إجمالي الدخل" FontSize="16" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtTotalIncome" Text="0" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="10,0"
                            Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource AppInputBg}">
                                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="إجمالي المصاريف" FontSize="16" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtTotalExpenses" Text="0" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="10,0"
                            Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource AppInputBg}">
                                <TextBlock Text="ل.س" FontSize="20" Foreground="#3B82F6" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="الصافي" FontSize="16" FontWeight="SemiBold" Foreground="#3B82F6" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtNetAmount" Text="0" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3"
                            Style="{StaticResource PanelCardStyle}"
                            Margin="10,0,0,0"
                            Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource AppInputBg}">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="عدد الزيارات (الحالات)" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtVisitCount" Text="0" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Action Bar -->
                <Border Grid.Row="2"
                        Style="{StaticResource PanelCardStyle}"
                        Padding="20"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search & Unpaid Buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnOpenSearchOverlay"
                                    Width="210" Height="48"
                                    Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOpenSearchOverlay_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="14,0,12,0" Foreground="White" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="بحث عن سجل لمريض" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="BtnOpenUnpaidOverlay"
                                    Width="180" Height="48" Margin="12,0,0,0"
                                    Background="#F59E0B" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOpenUnpaidOverlay_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="14,0,12,0" Foreground="White" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="حسابات لم تسدد" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Date Filters -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <DatePicker x:Name="DpFilterDate"
                                        Width="190" Height="48"
                                        CalendarOpened="DpFilterDate_CalendarOpened"
                                        SelectedDateChanged="DpFilterDate_SelectedDateChanged"/>

                            <Button x:Name="BtnCurrentDate"
                                    Margin="12,0,0,0" Height="48" Padding="16,0"
                                    Content="اليوم الحالي"
                                    Background="{DynamicResource AppInputBg}" Foreground="#3B82F6" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand" Visibility="Collapsed" Click="BtnCurrentDate_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <Border Grid.Column="4" Width="238" Height="48" HorizontalAlignment="Right" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnDayRange" Grid.Column="2" Content="يومي" Style="{StaticResource RangeButtonStyle}" Click="BtnDayRange_Click"/>
                                <Button x:Name="BtnMonthRange" Grid.Column="1" Content="شهري" Style="{StaticResource RangeButtonStyle}" Click="BtnMonthRange_Click"/>
                                <Button x:Name="BtnYearRange" Grid.Column="0" Content="سنوي" Style="{StaticResource RangeButtonStyle}" Click="BtnYearRange_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Income and Expenses Grid -->
                <Grid Grid.Row="3" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Income Section -->
                    <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="Transparent" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Padding="20" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="سجل الدخل" FontFamily="Traditional Arabic" FontSize="24" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#10B981" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Padding="20,14" Background="{DynamicResource AppInputBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="4" Text="التاريخ" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="3" Text="الوقت" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="اسم المريض/المصدر" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="الهاتف" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="0" Text="المبلغ المدفوع" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="2" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl x:Name="IncomeItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="20,16" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="4" Text="{Binding DateText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding TimeText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding PatientName}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                        <TextBlock Grid.Column="0" Text="{Binding PaidAmountText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#10B981" FontWeight="Bold" FontSize="16"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="EmptyIncomeText" Text="لا توجد سجلات دخل للفترة المحددة." Margin="0,36,0,36" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="3" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" x:Name="TxtIncomeFooterTotal" Text="0" FontSize="22" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="0" Text="المجموع الكلي للفترة المحددة" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondary}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Expenses Section -->
                    <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="Transparent" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Padding="20" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="المصاريف" FontFamily="Traditional Arabic" FontSize="24" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#EF4444" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Padding="20,14" Background="{DynamicResource AppWindowBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="112"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="+" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="24" FontWeight="Bold" Cursor="Hand" Click="BtnAddExpense_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBox x:Name="TxtExpenseAmount" Grid.Column="2" Style="{StaticResource InputBoxStyle}" TextAlignment="Center" Tag="القيمة"/>
                                    <TextBox x:Name="TxtExpenseDescription" Grid.Column="4" Style="{StaticResource InputBoxStyle}" TextAlignment="Right" Tag="التفاصيل..."/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Padding="20,14" Background="{DynamicResource AppInputBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="3" Text="التاريخ" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="الوقت" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="التفاصيل" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="0" Text="القيمة" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="3" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl x:Name="ExpenseItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="20,16" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="90"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="3" Text="{Binding DateText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Description}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="0" Text="{Binding AmountText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#EF4444" FontWeight="Bold" FontSize="16"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="EmptyExpenseText" Text="لا توجد مصاريف للفترة المحددة." Margin="0,36,0,36" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="4" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" x:Name="TxtExpenseFooterTotal" Text="0" FontSize="22" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="0" Text="مجموع المصاريف" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondary}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Upcoming Payments Section (دفعات قادمة) -->
                <Border Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource PanelCardStyle}" Margin="0,0,0,18" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="Transparent" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Padding="20,20,20,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="دفعات قادمة (مستحقات)" FontFamily="Traditional Arabic" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="1" Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#F59E0B" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Inputs -->
                        <Border Grid.Row="1" Padding="20,14" Background="{DynamicResource AppWindowBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="+" Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="24" FontWeight="Bold" Cursor="Hand" Click="BtnAddUpcoming_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <TextBox x:Name="TxtUpcomingAmount" Grid.Column="2" Style="{StaticResource InputBoxStyle}" TextAlignment="Center" Tag="القيمة"/>
                                <TextBox x:Name="TxtUpcomingDescription" Grid.Column="4" Style="{StaticResource InputBoxStyle}" TextAlignment="Right" Tag="تفاصيل الدفعة..."/>
                            </Grid>
                        </Border>

                        <!-- List Headers -->
                        <Border Grid.Row="2" Padding="20,14" Background="{DynamicResource AppInputBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="2" Text="التفاصيل" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="1" Text="القيمة" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="0" Text="الإجراءات" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Items -->
                        <ScrollViewer Grid.Row="3" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl x:Name="UpcomingItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="20,16" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="2" Text="{Binding Description}" VerticalAlignment="Center" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AmountText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#F59E0B" FontWeight="Bold" FontSize="16"/>
                                                    
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White" Background="#10B981" Width="40" Height="40" Margin="0,0,8,0" ToolTip="تم الدفع (تحويل للمصاريف)" Cursor="Hand" Click="BtnPayUpcoming_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="White" Background="#EF4444" Width="40" Height="40" ToolTip="إلغاء الدفعة" Cursor="Hand" Click="BtnCancelUpcoming_Click">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock x:Name="EmptyUpcomingText" Text="لا توجد دفعات قادمة مسجلة حالياً." Margin="0,36,0,36" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="30">
            <Border Width="280" Padding="24" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="جارٍ تحميل السجل المالي" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" TextAlignment="Center"/>
                    <TextBlock Text="يتم تجهيز الدخل والمصاريف والملخصات." Margin="0,8,0,18" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" TextAlignment="Center"/>
                    <ProgressBar Height="8" IsIndeterminate="True" Foreground="#3B82F6" Background="{DynamicResource AppInputBg}"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Unpaid Accounts Overlay -->
        <Border x:Name="UnpaidAccountsOverlay" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="40">
            <Border Width="850" MaxHeight="650" Background="{DynamicResource AppCardBg}" CornerRadius="22" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" Text="حسابات لم تسدد (الديون)" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="ترتيب حسب:" Margin="10,0" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                            <ComboBox x:Name="CmbUnpaidSort" Width="150" Height="36" SelectionChanged="CmbUnpaidSort_SelectionChanged" FlowDirection="RightToLeft">
                                <ComboBoxItem Content="الأعلى مديونية" IsSelected="True"/>
                                <ComboBoxItem Content="الأبجدية (أ-ي)"/>
                                <ComboBoxItem Content="الأقدم تاريخاً"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCloseUnpaidOverlay_Click"/>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource AppInputBg}" Padding="16,12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="3" Text="اسم المريض" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="رقم الهاتف" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="تاريخ أول دين" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="0" Text="المبلغ المتبقي" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="UnpaidItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="3" Text="{Binding PatientName}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource AppTextPrimary}" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PhoneNumber}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding FirstDebtDateText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                    <TextBlock Grid.Column="0" Text="{Binding RemainingAmountText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#EF4444" FontWeight="Bold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            
                            <TextBlock x:Name="EmptyUnpaidText" Grid.Row="1" Text="لا توجد حسابات غير مسددة." Margin="0,40" FontSize="15" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Patient Search History Overlay -->
        <Border x:Name="PatientSearchOverlay" Background="#99000000" Visibility="Collapsed" Panel.ZIndex="40">
            <Border Width="800" MaxHeight="600" Background="{DynamicResource AppCardBg}" CornerRadius="22" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="السجل المالي للمريض" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Left" VerticalAlignment="Center" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCloseSearchOverlay_Click"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,20" Panel.ZIndex="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBox x:Name="TxtPatientSearchInput" Grid.Row="0" Style="{StaticResource InputBoxStyle}" Tag="أدخل اسم المريض أو رقم الهاتف..." TextChanged="TxtPatientSearchInput_TextChanged" Height="46" FontSize="15"/>

                        <Border x:Name="SuggestionsPopupBorder" Grid.Row="1" Background="{DynamicResource AppCardBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0" MaxHeight="180" Visibility="Collapsed">
                            <ListBox x:Name="LstPatientSuggestions" BorderThickness="0" Background="Transparent" SelectionChanged="LstPatientSuggestions_SelectionChanged" DisplayMemberPath="DisplayName">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12" ClipToBounds="True" Panel.ZIndex="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="{DynamicResource AppInputBg}" Padding="16,12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="3" Text="التاريخ" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="الوقت" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="التكلفة/المسامحة" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="0" Text="المدفوع" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PatientHistoryItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="3" Text="{Binding DateText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TimeText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CostText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding CostColor}" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="0" Text="{Binding PaidText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#10B981" FontWeight="Bold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="EmptyPatientHistoryText" Grid.Row="1" Text="يرجى البحث واختيار مريض لعرض السجل." Margin="0,40" FontSize="15" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <Border x:Name="PatientHistoryFooter" Grid.Row="2" Background="{DynamicResource AppInputBg}" Padding="16,12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Add Payment Form -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button x:Name="BtnAddPatientPayment" Content="+" Background="#10B981" Foreground="White" BorderThickness="0" FontSize="22" FontWeight="Bold" Cursor="Hand" Width="40" Height="40" Click="BtnAddPatientPayment_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <TextBox x:Name="TxtAddPaymentAmount" Width="100" Height="40" Margin="10,0,0,0" Style="{StaticResource InputBoxStyle}" TextAlignment="Center" Tag="الدفعة"/>
                                        <TextBox x:Name="TxtAddForgivenessAmount" Width="100" Height="40" Margin="10,0,0,0" Style="{StaticResource InputBoxStyle}" TextAlignment="Center" Tag="مسامحة"/>
                                    </StackPanel>

                                    <!-- Summary Values -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtPatientTotalCost" Text="إجمالي التكلفة: 0" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,0,0,0"/>
                                        <TextBlock x:Name="TxtPatientTotalPaid" Text="إجمالي الدفعات: 0" FontSize="14" FontWeight="Bold" Foreground="#10B981" Margin="16,0,0,0"/>
                                        <TextBlock x:Name="TxtPatientTotalForgiven" Text="إجمالي المسامحة: 0" FontSize="14" FontWeight="Bold" Foreground="#F59E0B" Margin="16,0,0,0"/>
                                        <TextBlock x:Name="TxtPatientTotalRemaining" Text="المتبقي: 0" FontSize="14" FontWeight="Bold" Foreground="#EF4444" Margin="16,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>