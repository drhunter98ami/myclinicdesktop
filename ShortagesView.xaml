<UserControl x:Class="MyClinic.ShortagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <UserControl.Resources>
        <!-- نقل التنسيق إلى هنا لحل مشكلة الانهيار وعدم التعرف على الستايل -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- تنسيق قائمة العناصر -->
        <DataTemplate x:Key="ShortageItemTemplate">
            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="{Binding Item}" Foreground="{DynamicResource AppTextPrimary}" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    
                    <Button Grid.Column="1" Content="حذف" Background="#EF4444" Foreground="White" Width="60" Height="30" 
                            CommandParameter="{Binding}" Click="BtnDelete_Click" 
                            Style="{StaticResource RoundedButtonStyle}" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="إدارة النواقص" Foreground="{DynamicResource AppTextPrimary}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- قسم النواقص المستعجلة -->
            <Border Grid.Column="0" Background="{DynamicResource AppCardBg}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="نواقص مستعجلة" Foreground="#EF4444" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtUrgentInput" Height="40" FontSize="15" Padding="10,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" KeyDown="TxtUrgentInput_KeyDown"/>
                        <Button Grid.Column="1" Content="إضافة" Width="80" Height="40" Margin="10,0,0,0"
                                Background="#EF4444" Foreground="White" Style="{StaticResource RoundedButtonStyle}"
                                Click="BtnAddUrgent_Click"/>
                    </Grid>

                    <ListBox x:Name="ListUrgent" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                             ItemTemplate="{StaticResource ShortageItemTemplate}" HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>

            <!-- قسم النواقص غير المستعجلة -->
            <Border Grid.Column="2" Background="{DynamicResource AppCardBg}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="نواقص غير مستعجلة" Foreground="#F59E0B" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtNonUrgentInput" Height="40" FontSize="15" Padding="10,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" KeyDown="TxtNonUrgentInput_KeyDown"/>
                        <Button Grid.Column="1" Content="إضافة" Width="80" Height="40" Margin="10,0,0,0"
                                Background="#F59E0B" Foreground="White" Style="{StaticResource RoundedButtonStyle}"
                                Click="BtnAddNonUrgent_Click"/>
                    </Grid>

                    <ListBox x:Name="ListNonUrgent" Grid.Row="2" Background="Transparent" BorderThickness="0" 
                             ItemTemplate="{StaticResource ShortageItemTemplate}" HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>