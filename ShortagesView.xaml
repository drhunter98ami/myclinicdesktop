<UserControl x:Class="MyClinic.ShortagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortageComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="Transparent">
                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource AppCardBg}" BorderThickness="1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="8" Margin="0,4,0,8">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortageComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" Margin="2">
                            <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppSidebarHoverBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A10B981"/>
                                <Setter Property="Foreground" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ShortageItemTemplate">
            <Border Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Item}" Foreground="{DynamicResource AppTextPrimary}" FontSize="15" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PriceText}" Foreground="{DynamicResource AppTextSecondary}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="6" Padding="10,4" Margin="10,0,10,0" Background="#1A10B981" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrencyBadge}" Foreground="#10B981" FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                    <Button Grid.Column="2" Content="حذف" Background="#EF4444" Foreground="White" Width="60" Height="30"
                            CommandParameter="{Binding}" Click="BtnDelete_Click"
                            Style="{StaticResource RoundedButtonStyle}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="إدارة النواقص" Foreground="{DynamicResource AppTextPrimary}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- قسم النواقص المستعجلة (أخضر) -->
            <Border Grid.Column="0" Background="{DynamicResource AppCardBg}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="نواقص مستعجلة" Foreground="#10B981" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtUrgentInput" Height="40" FontSize="15" Padding="10,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" KeyDown="TxtUrgentInput_KeyDown"/>
                        <TextBox Grid.Column="1" x:Name="TxtUrgentPrice" Height="40" FontSize="15" Padding="10,0" Margin="8,0,0,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" ToolTip="السعر"/>
                        <ComboBox Grid.Column="2" x:Name="CmbUrgentCurrency" Height="40" Margin="8,0,0,0"
                                  Style="{StaticResource ShortageComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource ShortageComboBoxItemStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="USD"/>
                            <ComboBoxItem Content="SYP"/>
                        </ComboBox>
                        <Button Grid.Column="3" Content="إضافة" Height="40" Margin="8,0,0,0"
                                Background="#10B981" Foreground="White" Style="{StaticResource RoundedButtonStyle}"
                                Click="BtnAddUrgent_Click"/>
                    </Grid>

                    <ListBox x:Name="ListUrgent" Grid.Row="2" Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource ShortageItemTemplate}" HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                    <Border Grid.Row="3" Background="#1A10B981" CornerRadius="8" Padding="14,10" Margin="0,12,0,0">
                        <Grid>
                            <TextBlock Text="المجموع" Foreground="#10B981" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtUrgentTotal" Text="0 ل.س" Foreground="{DynamicResource AppTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- قسم النواقص غير المستعجلة -->
            <Border Grid.Column="2" Background="{DynamicResource AppCardBg}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="نواقص غير مستعجلة" Foreground="#F59E0B" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtNonUrgentInput" Height="40" FontSize="15" Padding="10,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" KeyDown="TxtNonUrgentInput_KeyDown"/>
                        <TextBox Grid.Column="1" x:Name="TxtNonUrgentPrice" Height="40" FontSize="15" Padding="10,0" Margin="8,0,0,0" VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBg}" Foreground="{DynamicResource AppTextPrimary}"
                                 BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" ToolTip="السعر"/>
                        <ComboBox Grid.Column="2" x:Name="CmbNonUrgentCurrency" Height="40" Margin="8,0,0,0"
                                  Style="{StaticResource ShortageComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource ShortageComboBoxItemStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="USD"/>
                            <ComboBoxItem Content="SYP"/>
                        </ComboBox>
                        <Button Grid.Column="3" Content="إضافة" Height="40" Margin="8,0,0,0"
                                Background="#F59E0B" Foreground="White" Style="{StaticResource RoundedButtonStyle}"
                                Click="BtnAddNonUrgent_Click"/>
                    </Grid>

                    <ListBox x:Name="ListNonUrgent" Grid.Row="2" Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource ShortageItemTemplate}" HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                    <Border Grid.Row="3" Background="#1AF59E0B" CornerRadius="8" Padding="14,10" Margin="0,12,0,0">
                        <Grid>
                            <TextBlock Text="المجموع" Foreground="#F59E0B" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtNonUrgentTotal" Text="0 ل.س" Foreground="{DynamicResource AppTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
