<UserControl x:Class="MyClinic.PatientRecordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{DynamicResource AppWindowBg}"
             FontFamily="Segoe UI"
             FontSize="14"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">

    <UserControl.Resources>
        <Style x:Key="FilterShellStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CardActionButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="11,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="VisitEntryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModalHeaderChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DetailSectionStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource AppCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Width" Value="146"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource AppInputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Margin="0,0,0,26"
                Padding="28,24"
                CornerRadius="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#042C2A" Offset="0"/>
                    <GradientStop Color="#053A38" Offset="0.55"/>
                    <GradientStop Color="#054543" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#20000000" BlurRadius="28" ShadowDepth="12" Opacity="0.28"/>
            </Border.Effect>

            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,24,0">
                    <Border Style="{StaticResource FilterShellStyle}"
                            Width="315"
                            Margin="0,0,16,0">
                        <Grid>
                            <TextBox x:Name="TxtPhoneSearch"
                                     Style="{StaticResource FilterTextBoxStyle}"
                                     Padding="18,0,58,0"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="بحث عن طريق الرقم"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       FontSize="17"
                                       Margin="0,0,58,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtPhoneSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="&#xE717;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Margin="0,0,18,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource FilterShellStyle}"
                            Width="315">
                        <Grid>
                            <TextBox x:Name="TxtNameSearch"
                                     Style="{StaticResource FilterTextBoxStyle}"
                                     Padding="18,0,58,0"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="بحث بالاسم..."
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       FontSize="17"
                                       Margin="0,0,58,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtNameSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Margin="0,0,18,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            FlowDirection="RightToLeft"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="سجل المرضى"
                               FontFamily="Traditional Arabic"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="إدارة ملفات المرضى ومتابعة سجلاتهم الطبية"
                               FontSize="18"
                               Foreground="#C6ECE6"
                               HorizontalAlignment="Right"
                               Margin="0,-10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Patient list ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <ListBox x:Name="PatientsListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     Margin="0,4,0,0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- NOTE: Leaving the patient card with its absolute dark green styling to act as visually distinct "credit card" style records in both themes -->
                        <Border Margin="12,0,12,14"
                                Padding="20,16"
                                VerticalAlignment="Top"
                                CornerRadius="20"
                                BorderBrush="#0A4E4B"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E6E6A" Offset="0"/>
                                    <GradientStop Color="#0F6560" Offset="0.55"/>
                                    <GradientStop Color="#0B615C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid FlowDirection="RightToLeft">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="56"
                                        Height="56"
                                        CornerRadius="18"
                                        Background="#3A7773">
                                    <TextBlock Text="&#xE77B;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="26"
                                               Foreground="#ECFBF8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="16,0,16,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontFamily="Traditional Arabic"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Right"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,-2,0,0">
                                        <TextBlock Text="{Binding PhoneNumber}"
                                                   FontSize="15"
                                                   Foreground="#D8F3EE"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="&#xE717;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#D8F3EE"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,24,0">
                                    <Border Padding="14,8"
                                            CornerRadius="18"
                                            Background="#0B5752"
                                            Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="الجنس:" FontSize="13" Foreground="#9DD1CC" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding GenderLabel}" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="14,8"
                                            CornerRadius="18"
                                            Background="#0B5752">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="العمر:" FontSize="13" Foreground="#9DD1CC" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding AgeText}" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource CardActionButtonStyle}"
                                            Background="#F8FAFB"
                                            Foreground="#0C4340"
                                            Padding="16,0"
                                            Tag="{Binding}"
                                            Click="OpenMedicalRecord_Click">
                                        <StackPanel Orientation="Horizontal"
                                                    FlowDirection="RightToLeft">
                                            <TextBlock Text="سجل الزيارات"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       Margin="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="&#xE76C;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Width="110"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource CardActionButtonStyle}"
                                            Background="Transparent"
                                            BorderBrush="#21716C"
                                            BorderThickness="1"
                                            Foreground="#F2FAF9"
                                            Tag="{Binding}"
                                            Click="OpenMedicalRecord_Click">
                                        <StackPanel Orientation="Horizontal"
                                                    FlowDirection="RightToLeft"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding VisitCountLabel}"
                                                       FontSize="16"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="&#xE787;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="17"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="EmptyStateCard"
                    Width="420"
                    Padding="28"
                    CornerRadius="24"
                    Background="{DynamicResource AppCardBg}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="44"
                               Foreground="{DynamicResource AppTextSecondary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyStateTitle"
                               Text="لا توجد نتائج مطابقة"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Margin="0,10,0,8"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyStateDescription"
                               Text="جرّب البحث باسم مختلف أو رقم هاتف آخر."
                               FontSize="15"
                               Foreground="{DynamicResource AppTextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="LoadingOverlay"
                    Panel.ZIndex="10"
                    Visibility="Collapsed"
                    Background="#99000000"
                    CornerRadius="24">
                <Border Width="260"
                        Padding="24"
                        CornerRadius="20"
                        Background="{DynamicResource AppCardBg}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="جارٍ تحميل سجل المرضى"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   TextAlignment="Center"/>
                        <TextBlock Text="يتم تجهيز البيانات بشكل أخف وأسرع."
                                   Margin="0,8,0,18"
                                   FontSize="14"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   TextAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True"
                                     Height="8"
                                     Foreground="#0DA49A"
                                     Background="{DynamicResource AppInputBg}"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- ═══ Medical record drawer ════════════════════════════════════════════ -->
        <Grid x:Name="MedicalRecordOverlay"
              Grid.RowSpan="2"
              Panel.ZIndex="20"
              Visibility="Collapsed">
            <Border x:Name="OverlayDimmer"
                    Background="#80000000"
                    Opacity="0"
                    MouseLeftButtonDown="OverlayDimmer_MouseLeftButtonDown"/>

            <Border x:Name="MedicalRecordDrawer"
                    Width="430"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppWindowBg}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="DrawerTranslate" X="-48"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#28000000" BlurRadius="34" ShadowDepth="8" Opacity="0.26"/>
                </Border.Effect>

                <Grid FlowDirection="RightToLeft">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="28,18,28,12"
                          FlowDirection="LeftToRight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="34"
                                Height="34"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CloseMedicalRecord_Click">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <StackPanel Grid.Column="1"
                                    FlowDirection="RightToLeft"
                                    HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="الملف الطبي"
                                           FontFamily="Traditional Arabic"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextPrimary}"
                                           Margin="0,0,12,0"/>
                                <Border Width="7"
                                        Height="40"
                                        CornerRadius="4"
                                        Background="#0DA49A"/>
                            </StackPanel>
                            <TextBlock Text="استعراض التاريخ المرضي والزيارات السابقة"
                                       FontSize="14"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       HorizontalAlignment="Right"
                                       Margin="0,-8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="28,0,28,20"
                            Padding="20"
                            CornerRadius="18"
                            Background="{DynamicResource AppCardBg}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1">
                        <Grid x:Name="DrawerPatientInfoCard">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="58"
                                    Height="58"
                                    CornerRadius="29"
                                    Background="{DynamicResource AppInputBg}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1">
                                <TextBlock Text="&#xE77B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="26"
                                           Foreground="#0A6A63"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,14,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontFamily="Traditional Arabic"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextPrimary}"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,8,0,0">
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding GenderLabel}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AppTextSecondary}"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}" Margin="0">
                                        <TextBlock Text="{Binding AgeWithUnit}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AppTextSecondary}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,0,28,28">
                            <Border Margin="0,0,0,18"
                                    Padding="16"
                                    CornerRadius="14"
                                    Background="{DynamicResource AppInputBg}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="تجد هنا جميع الزيارات والسجلات الطبية المحفوظة لهذا المريض."
                                               FontSize="13"
                                               Foreground="{DynamicResource AppTextSecondary}"
                                               TextWrapping="Wrap"
                                               Width="320"
                                               TextAlignment="Right"/>
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="{DynamicResource AppTextSecondary}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Top"/>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        MinWidth="28"
                                        Height="28"
                                        Padding="8,0"
                                        CornerRadius="8"
                                        Background="{DynamicResource AppInputBg}">
                                    <TextBlock x:Name="VisitCounterBadge"
                                               Text="0"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextPrimary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1"
                                           x:Name="VisitScopeText"
                                           Text="الزيارات المسجلة"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextPrimary}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <ListBox x:Name="VisitsListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource VisitEntryButtonStyle}"
                                                Tag="{Binding}"
                                                Click="OpenVisitDetails_Click">
                                            <Border Margin="0,0,0,14"
                                                    Padding="16"
                                                    CornerRadius="14"
                                                    Background="{DynamicResource AppCardBg}"
                                                    BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0"
                                                          FlowDirection="LeftToRight">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding VisitDateText}"
                                                                   FontSize="15"
                                                                   Foreground="{DynamicResource AppTextSecondary}"/>

                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    FlowDirection="RightToLeft">
                                                            <TextBlock Text="&#xE8A5;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="15"
                                                                       Foreground="{DynamicResource AppTextSecondary}"
                                                                       Margin="0,0,8,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding AttachmentLabel}"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource AppTextSecondary}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Title}"
                                                               FontFamily="Traditional Arabic"
                                                               FontSize="22"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource AppTextPrimary}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Right"
                                                               Margin="0,10,0,6"/>

                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="&#xE76C;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource AppTextSecondary}"
                                                                   VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Details}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource AppTextSecondary}"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Right"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock x:Name="EmptyVisitsText"
                                       Text="لا توجد زيارات محفوظة لهذا المريض حتى الآن."
                                       FontSize="15"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Visit details modal ═══════════════════════════════════════════════ -->
        <Grid x:Name="VisitDetailsOverlay"
              Grid.RowSpan="2"
              Panel.ZIndex="30"
              Visibility="Collapsed">
            <Border x:Name="VisitDetailsDimmer"
                    Background="#80000000"
                    Opacity="0"
                    MouseLeftButtonDown="VisitDetailsDimmer_MouseLeftButtonDown"/>

            <Border x:Name="VisitDetailsModal"
                    Width="760"
                    MaxHeight="900"
                    Margin="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppWindowBg}"
                    CornerRadius="28">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="VisitDetailsTranslate" Y="24"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#26000000" BlurRadius="36" ShadowDepth="10" Opacity="0.28"/>
                </Border.Effect>

                <Grid FlowDirection="RightToLeft">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="28,18,28,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="34"
                                Height="34"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CloseVisitDetails_Click">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Border Width="52"
                                        Height="52"
                                        CornerRadius="16"
                                        Background="#DCE8FF"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="&#xE8A5;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="#2563EB"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="تفاصيل الزيارة الطبية"
                                               FontFamily="Traditional Arabic"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextPrimary}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding PatientName}"
                                               FontSize="15"
                                               Foreground="{DynamicResource AppTextSecondary}"
                                               HorizontalAlignment="Right"
                                               Margin="0,-8,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid HorizontalAlignment="Right"
                                  Margin="0,18,0,0"
                                  FlowDirection="LeftToRight">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource ModalHeaderChipStyle}">
                                    <StackPanel Orientation="Horizontal"
                                                FlowDirection="RightToLeft">
                                        <TextBlock Text="&#xE823;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="#0EA5A8"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VisitDateTimeText}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AppTextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource ModalHeaderChipStyle}">
                                    <StackPanel Orientation="Horizontal"
                                                FlowDirection="RightToLeft">
                                        <TextBlock Text="&#xE77B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="#2563EB"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DoctorName}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AppTextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="0"
                            Height="1"
                            Background="{DynamicResource AppBorder}"
                            VerticalAlignment="Bottom"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="28,20,28,6">
                        <StackPanel>
                            <!-- Patient info section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,0,16">
                                        <TextBlock Text="&#xE77B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="20"
                                                   Foreground="#7C3AED"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="معلومات المريض عند وقت الزيارة"
                                                   FontFamily="Traditional Arabic"
                                                   FontSize="25"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AppTextPrimary}"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="زمرة الدم" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding BloodTypeText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الحساسية" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding AllergiesText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الأمراض المزمنة" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding ChronicDiseasesText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="عادات التدخين" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding SmokingText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="16" Padding="16">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الحمل والرضاعة" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PregnancyText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Vital signs section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,0,16">
                                        <TextBlock Text="&#xEC42;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="20"
                                                   Foreground="#1D4ED8"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="العلامات الحيوية (Vital Signs)"
                                                   FontFamily="Traditional Arabic"
                                                   FontSize="25"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AppTextPrimary}"/>
                                    </StackPanel>

                                    <WrapPanel HorizontalAlignment="Right">
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="ضغط الدم" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding BloodPressureText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="النبض" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding HeartRateText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الحرارة" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding TemperatureText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="التنفس" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding RespiratoryRateText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الوزن" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding WeightText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="الطول" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding HeightText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="BMI" FontSize="14" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding BmiText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Symptoms + Diagnosis -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DetailSectionStyle}" Margin="0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,14">
                                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#B45309" Margin="0,0,10,0"/>
                                            <TextBlock Text="الأعراض (Symptoms)" FontFamily="Traditional Arabic" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SymptomsText}" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" TextWrapping="Wrap" TextAlignment="Right"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DetailSectionStyle}" Margin="0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,14">
                                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1D4ED8" Margin="0,0,10,0"/>
                                            <TextBlock Text="التشخيص (Diagnosis)" FontFamily="Traditional Arabic" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DiagnosisText}" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" TextWrapping="Wrap" TextAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Dental chart -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE8D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#DB2777" Margin="0,0,10,0"/>
                                        <TextBlock Text="حالة الأسنان (Dental Chart)" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="فئة المريض:" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Padding="12,6" CornerRadius="10" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding DentalChartCategoryText}" FontSize="17" Foreground="{DynamicResource AppTextPrimary}"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="الأسنان المعالجة:" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right" Margin="0,0,0,10"/>

                                    <ItemsControl ItemsSource="{Binding Teeth}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="58" Height="58" Margin="0,0,10,10" CornerRadius="29" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="2">
                                                    <TextBlock Text="{Binding}" FontSize="18" FontWeight="Bold" Foreground="#DB2777" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTeeth}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>

                                    <TextBlock Text="لا توجد أسنان مسجلة لهذه الزيارة." FontSize="17" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTeeth}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Treatment plan -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <TextBlock Text="الخطة العلاجية والملاحظات" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding TreatmentPlanText}" FontSize="18" Foreground="{DynamicResource AppTextPrimary}" TextWrapping="Wrap" TextAlignment="Right" Margin="0,12,0,0"/>

                                    <StackPanel Margin="0,18,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasFinalTreatment}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="الإجراء النهائي" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding FinalTreatmentText}" FontSize="18" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap" TextAlignment="Right" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Selected Treatments section -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#0EA5A8" Margin="0,0,10,0"/>
                                        <TextBlock Text="العلاجات المحددة" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding SelectedTreatments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8" Padding="16,12" CornerRadius="14" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding TreatmentName}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center" TextAlignment="Right"/>
                                                        <Border Grid.Column="1" Padding="10,4" CornerRadius="8" Background="#E0F2FE" Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <TextBlock FontSize="14" Foreground="#0369A1">
                                                                <Run Text="×"/>
                                                                <Run Text="{Binding Quantity}"/>
                                                            </TextBlock>
                                                        </Border>
                                                        <Border Grid.Column="2" Padding="10,4" CornerRadius="8" Background="#F0FDF4" VerticalAlignment="Center">
                                                            <TextBlock FontSize="14" Foreground="#15803D" FontWeight="SemiBold">
                                                                <Run Text="{Binding Cost, StringFormat={}{0:0.##}}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding Currency}"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedTreatments}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>

                                    <TextBlock Text="لا توجد علاجات محددة لهذه الزيارة." FontSize="17" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedTreatments}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Prescription -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#15803D" Margin="0,0,10,0"/>
                                        <TextBlock Text="الوصفة الطبية" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}"/>
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding PrescriptionItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,12" Padding="18" CornerRadius="16" Background="{DynamicResource AppInputBg}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding MedicineName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding InstructionText}" FontSize="16" Foreground="{DynamicResource AppTextSecondary}" TextWrapping="Wrap" TextAlignment="Right" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPrescriptions}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>

                                    <TextBlock Text="لا توجد وصفة طبية مرفقة لهذه الزيارة." FontSize="17" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPrescriptions}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Attachments -->
                            <Border Style="{StaticResource DetailSectionStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="المرفقات والصور" FontFamily="Traditional Arabic" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" HorizontalAlignment="Right"/>
                                        <Border Grid.Column="1" Padding="10,4" CornerRadius="10" Background="{DynamicResource AppInputBg}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AttachmentCountText}" FontSize="14" Foreground="{DynamicResource AppTextPrimary}"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AppTextSecondary}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding AttachmentItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="208" Height="208" Margin="0,0,12,12" Padding="0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Tag="{Binding}" Click="OpenAttachment_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="18" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Background="{DynamicResource AppInputBg}" ClipToBounds="True">
                                                                <Grid>
                                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    <Border VerticalAlignment="Bottom" Background="#80000000" Padding="10,8">
                                                                        <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>

                                    <TextBlock Text="لا توجد صور أو مرفقات لهذه الزيارة." FontSize="17" Foreground="{DynamicResource AppTextSecondary}" HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAttachments}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Padding="16"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,1,0,0">
                        <Button Content="إغلاق"
                                Width="96"
                                Height="42"
                                Background="{DynamicResource AppInputBg}"
                                BorderBrush="{DynamicResource AppBorder}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Click="CloseVisitDetails_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>